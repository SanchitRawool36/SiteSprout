<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin | SiteSprout</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/mobile.css">
</head>
<body>
  <div class="page-container">
    <div class="sidebar">
      <div class="sidebar-header">
        <h2 class="brand">SiteSprout</h2>
      </div>
      <ul class="sidebar-menu">
        <li class="menu-item active">
          <a href="#"><i class="fas fa-store-alt"></i> Restaurant</a>
        </li>
        <li class="menu-item">
          <a href="#"><i class="fas fa-cog"></i> Settings</a>
        </li>
      </ul>
    </div>
    <div class="main-content">
      <header class="main-header">
        <button class="mobile-menu-btn" id="mobileMenuBtn">
    <i class="fas fa-bars"></i>
</button>
<h1 class="header-title"><%= restaurant ? 'Edit Restaurant' : 'Create Restaurant' %></h1>
        <div class="header-actions">
          <% if (restaurant) { %>
            <a href="/<%= restaurant.slug %>" class="btn btn-outline" target="_blank">
              <i class="fas fa-eye"></i> Preview
            </a>
          <% } %>
          <button type="submit" form="restaurantForm" class="btn btn-primary">
            <i class="fas fa-save"></i> <%= restaurant ? 'Update' : 'Create' %>
          </button>
        </div>
      </header>
      <div class="content-wrapper">
        <form action="<%= restaurant ? '/update' : '/create' %>" method="POST" class="admin-form" enctype="multipart/form-data" id="restaurantForm">
          <input type="hidden" id="menuJson" name="menuJson">
          <% if (restaurant) { %>
            <input type="hidden" name="restaurantId" value="<%= restaurant._id %>">
          <% } %>

          <div class="form-section">
            <h3 class="section-title">Basic Information</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="name">Restaurant Name</label>
                <input type="text" id="name" name="name" required value="<%= restaurant ? restaurant.name : '' %>">
              </div>
              <div class="form-group">
                <label for="slug">URL Slug</label>
                <input type="text" id="slug" name="slug" value="<%= restaurant ? restaurant.slug : '' %>">
              </div>
              <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3"><%= restaurant ? restaurant.description : '' %></textarea>
              </div>
              <div class="form-group">
                <label for="businessType">Business Type</label>
                <select id="businessType" name="businessType">
                  <option value="Restaurant" <%= restaurant && restaurant.businessType === 'Restaurant' ? 'selected' : '' %>>Restaurant</option>
                  <option value="Cafe" <%= restaurant && restaurant.businessType === 'Cafe' ? 'selected' : '' %>>Cafe</option>
                  <option value="FastFood" <%= restaurant && restaurant.businessType === 'FastFood' ? 'selected' : '' %>>Fast Food</option>
                  <option value="QSR" <%= restaurant && restaurant.businessType === 'QSR' ? 'selected' : '' %>>QSR</option>
                </select>
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="section-title">Branding & Theme</h3>
            <div class="form-grid">
              <div class="form-group">
                <label for="logo">Logo</label>
                <input type="file" id="logo" name="logo" accept="image/*">
              </div>
              <div class="form-group">
                <label for="themeColor">Theme Color</label>
                <input type="color" id="themeColor" name="themeColor" value="<%= restaurant ? restaurant.themeColor : '#3b82f6' %>">
              </div>
              <div class="form-group">
                <label for="themeChoice">Theme</label>
                <select id="themeChoice" name="themeChoice">
                  <option value="restro" <%= restaurant && restaurant.themeChoice === 'restro' ? 'selected' : '' %>>Restro</option>
                  <option value="cafe" <%= restaurant && restaurant.themeChoice === 'cafe' ? 'selected' : '' %>>Cafe</option>
                  <option value="fastfood" <%= restaurant && restaurant.themeChoice === 'fastfood' ? 'selected' : '' %>>Fast Food</option>
                </select>
              </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="section-title">Hero Section</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label for="heroHeadline">Hero Headline</label>
                    <input type="text" id="heroHeadline" name="hero[headline]" value="<%= restaurant && restaurant.hero ? restaurant.hero.headline : '' %>">
                  </div>
                  <div class="form-group">
                    <label for="heroSubheadline">Hero Subheadline</label>
                    <input type="text" id="heroSubheadline" name="hero[subheadline]" value="<%= restaurant && restaurant.hero ? restaurant.hero.subheadline : '' %>">
                  </div>
                  <div class="form-group">
                    <label for="heroImage">Hero Image</label>
                    <input type="file" id="heroImage" name="heroImage" accept="image/*">
                  </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="section-title">Contact Information</h3>
            <div class="form-grid">
                <div class="form-group">
                    <label for="openingHours">Opening Hours</label>
                    <input type="text" id="openingHours" name="openingHours" value="<%= restaurant ? restaurant.openingHours : '' %>">
                  </div>
                  <div class="form-group">
                    <label for="phone">Phone Number</label>
                    <input type="tel" id="phone" name="phone" value="<%= restaurant ? restaurant.phone : '' %>">
                  </div>
                  <div class="form-group">
                    <label for="address">Address</label>
                    <input type="text" id="address" name="address" value="<%= restaurant ? restaurant.address : '' %>">
                  </div>
                  <div class="form-group">
                    <label for="socialInstagram">Instagram URL</label>
                    <input type="url" id="socialInstagram" name="social[instagram]" value="<%= restaurant && restaurant.social ? restaurant.social.instagram : '' %>">
                  </div>
                  <div class="form-group">
                    <label for="socialFacebook">Facebook URL</label>
                    <input type="url" id="socialFacebook" name="social[facebook]" value="<%= restaurant && restaurant.social ? restaurant.social.facebook : '' %>">
                  </div>
            </div>
          </div>

          <div class="form-section">
            <h3 class="section-title">Image Gallery</h3>
            <div class="form-group">
              <label for="gallery">Upload Images</label>
              <input type="file" id="gallery" name="gallery" multiple accept="image/*">
            </div>
            <% if (restaurant && restaurant.gallery && restaurant.gallery.length > 0) { %>
              <div class="gallery-preview">
                <% restaurant.gallery.forEach(img => { %>
                  <div class="gallery-image">
                    <img src="<%= img %>" alt="Gallery Image">
                    <button type="button" class="remove-image" data-image-url="<%= img %>">&times;</button>
                  </div>
                <% }) %>
              </div>
            <% } %>
            <input type="hidden" name="removedImages" id="removedImages">
          </div>

          <div class="form-section">
            <h3 class="section-title">Menu</h3>
            <div id="categoriesContainer"></div>
            <button id="addCategoryBtn" type="button" class="btn btn-outline">
              <i class="fas fa-plus"></i> Add Category
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const rawMenuData = <%- restaurant && restaurant.menu ? JSON.stringify(restaurant.menu) : '[]' %>;
  </script>
  <script src="/js/admin.js"></script>
</body>
</html>