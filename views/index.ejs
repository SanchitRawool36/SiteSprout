<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SiteSprout - Build Your Professional Website in Minutes</title>
  <meta name="description" content="Create a stunning website with our easy-to-use platform. No coding required. Get online in minutes with professional templates and features.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/mobile.css">
</head>
<body>

  <header class="site-header">
    <nav class="nav-container">
      <div class="nav-brand">
        <a href="/" class="logo">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
          SiteSprout
        </a>
      </div>
      
      <div class="nav-menu" id="navMenu">
        <a href="#features" class="nav-link">Features</a>
        <a href="#templates" class="nav-link">Templates</a>
        <a href="#pricing" class="nav-link">Pricing</a>
        <a href="/login" class="nav-link">Login</a>
        <a href="/admin" class="btn btn-primary">Get Started</a>
      </div>
      
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>
  </header>

  <section class="hero-section">
    <div class="hero-container">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge-text">✨ No Coding Required</span>
        </div>
        <h1 class="hero-title">
          Build Your Stunning Website in
          <span class="gradient-text">Minutes</span>
        </h1>
        <p class="hero-description">
          Our intuitive platform empowers you to create a professional online presence without any coding.
          Showcase your business, portfolio, or online store with beautiful, responsive templates.
        </p>
        <div class="hero-actions">
          <a href="/admin" class="btn btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            Build Your Website for Free
          </a>
          <a href="#templates" class="btn btn-secondary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
            Browse Themes
          </a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">1,500+</span>
            <span class="stat-label">Websites Built</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">3 Mins</span>
            <span class="stat-label">Average Setup</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">Top-Tier</span>
            <span class="stat-label">Support</span>
          </div>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-mockup">
            <div class="mockup-browser">
              <div class="browser-header">
                <div class="browser-dots">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
              <div class="browser-content">
                <img src="https://via.placeholder.com/600x400.png/f0f0f0/cccccc?text=Your+Beautiful+Website" alt="Website preview" class="mockup-image">
              </div>
            </div>
        </div>
      </div>
    </div>
  </section>

  <section class="features-section" id="features">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Everything you need to create a stunning website</h2>
        <p class="section-description">
          Our platform is packed with powerful features to help you succeed online.
        </p>
      </div>
      
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
          </div>
          <h3 class="feature-title">Professionally Designed Themes</h3>
          <p class="feature-description">
            Choose from a variety of beautiful, fully customizable themes to match your brand and style.
          </p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"></path></svg>
          </div>
          <h3 class="feature-title">Easy-to-Use Website Builder</h3>
          <p class="feature-description">
            Our intuitive drag-and-drop builder makes it simple to customize your site. No coding skills needed.
          </p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 4 16.25"></path><path d="M8 10h.01"></path></svg>
          </div>
          <h3 class="feature-title">Responsive by Default</h3>
          <p class="feature-description">
            Your website will look perfect on any device, from desktops to smartphones, without any extra effort.
          </p>
        </div>
        
        <div class="feature-card">
          <div class="feature-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="14.31" y1="8" x2="20.05" y2="17.94"></line><line x1="9.69" y1="8" x2="21.17" y2="8"></line><line x1="7.38" y1="12" x2="13.12" y2="2.06"></line><line x1="9.69" y1="16" x2="3.95" y2="6.06"></line><line x1="14.31" y1="16" x2="2.83" y2="16"></line><line x1="16.62" y1="12" x2="10.88" y2="21.94"></line></svg>
          </div>
          <h3 class="feature-title">Optimized for Performance</h3>
          <p class="feature-description">
            We optimize your site for speed, ensuring a smooth and enjoyable experience for your visitors.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="templates-section" id="templates">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Beautiful Themes for Any Industry</h2>
        <p class="section-description">
          Get a professional design that fits your brand, no matter what business you're in.
        </p>
      </div>
      
      <div class="templates-grid">
        <div class="template-card">
          <div class="template-preview">
            <img src="https://via.placeholder.com/400x300.png/e0e7ff/8b5cf6?text=Modern+Cafe" alt="Cafe & Restaurant Template" class="template-image">
            <div class="template-overlay">
              <a href="/admin" class="btn btn-white">Use This Template</a>
            </div>
          </div>
          <div class="template-info">
            <h3 class="template-name">Modern Cafe & Restaurant</h3>
            <p class="template-description">A theme designed to showcase your menu and attract more customers.</p>
          </div>
        </div>
        
        <div class="template-card">
          <div class="template-preview">
            <img src="https://via.placeholder.com/400x300.png/dcfce7/34d399?text=Creative+Portfolio" alt="Portfolio Template" class="template-image">
            <div class="template-overlay">
              <a href="/admin" class="btn btn-white">Use This Template</a>
            </div>
          </div>
          <div class="template-info">
            <h3 class="template-name">Stylish Creative Portfolio</h3>
            <p class="template-description">A beautiful and modern way to showcase your creative work and projects.</p>
          </div>
        </div>
        
        <div class="template-card">
          <div class="template-preview">
            <img src="https://via.placeholder.com/400x300.png/fee2e2/f87171?text=Small+Business" alt="Business Template" class="template-image">
            <div class="template-overlay">
              <a href="/admin" class="btn btn-white">Use This Template</a>
            </div>
          </div>
          <div class="template-info">
            <h3 class="template-name">Professional Small Business</h3>
            <p class="template-description">A clean and professional look to build trust with your customers and clients.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="cta-title">Ready to Build Your Online Presence?</h2>
        <p class="cta-description">
          Join thousands of creators and entrepreneurs who have built their websites with SiteSprout.
        </p>
        <div class="cta-actions">
          <a href="/admin" class="btn btn-primary btn-large">
            Start Building Now
          </a>
          <div class="cta-note">
            <span>✓ No credit card required</span>
            <span>✓ Launch in minutes</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <div class="logo">SiteSprout</div>
          <p class="footer-description">
            The simplest way to create a professional website.
          </p>
        </div>
        <div class="footer-links">
          <div class="footer-column">
            <h4>Product</h4>
            <a href="#features">Features</a>
            <a href="#templates">Templates</a>
            <a href="#pricing">Pricing</a>
          </div>
          <div class="footer-column">
            <h4>Company</h4>
            <a href="#">About Us</a>
            <a href="#">Careers</a>
            <a href="#">Contact</a>
          </div>
          <div class="footer-column">
            <h4>Legal</h4>
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2024 SiteSprout. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script src="/js/homepage.js"></script>
</body>
</html>