<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Dashboard - SiteSprout</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container" style="max-width:860px;margin:3rem auto;">
    <a class="back-home" href="/">← Home</a>
    <div class="card" style="padding:1.5rem;">
      <h1 style="margin:0 0 0.5rem;">Dashboard</h1>
      <p class="muted" style="margin-bottom:1rem;">Manage your SiteSprout websites from here.</p>

      <% if (restaurant) { %>
        <div class="card-glass dashboard-cards" style="padding:1rem;margin-bottom:1rem;display:grid;grid-template-columns:1fr 260px;gap:1rem;align-items:start;">
          <div>
            <h3 style="margin:0 0 0.25rem;">Your Site is Live <span style="color:var(--success-green);font-weight:700;margin-left:0.5rem">● Live</span></h3>
            <p class="muted">Public URL</p>
            <div style="display:flex;gap:0.75rem;align-items:center;margin-top:0.5rem;">
              <input id="siteLink" readonly style="flex:1;padding:0.6rem;border-radius:8px;border:1px solid rgba(16,24,40,0.06);background:rgba(255,255,255,0.9)" value="/<%= restaurant.slug %>">
              <button id="copyLinkBtn" class="btn ghost" data-link="/<%= restaurant.slug %>">Copy</button>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;gap:0.5rem;justify-content:center;align-items:flex-end;">
            <a class="btn cta" href="/admin?slug=<%= restaurant.slug %>">Edit Site</a>
            <button id="deleteBtn" class="btn danger">Delete Site</button>
            <div class="analytics card-glass" style="padding:0.5rem 0.75rem;text-align:left;width:100%;">
              <strong style="display:block">Analytics</strong>
              <small class="muted">Total Visits: 0</small>
            </div>
          </div>
        </div>
        
        <!-- Delete Confirmation Modal -->
        <div id="deleteModal" class="modal" style="display:none;">
          <div class="modal-content">
            <h2>Confirm Deletion</h2>
            <p>Are you sure you want to delete this site? This action cannot be undone.</p>
            <div class="modal-actions">
              <button id="cancelDelete" class="btn">Cancel</button>
              <a href="/delete/<%= restaurant._id %>" class="btn danger">Confirm Delete</a>
            </div>
          </div>
        </div>
      <% } else { %>
        <div style="text-align:center;padding:2rem;">
          <p class="lead">You don't have a site yet.</p>
          <a class="btn cta large" href="/admin">Create Your First Restaurant Website</a>
        </div>
      <% } %>
    </div>
  </div>

  <script src="/js/dashboard.js"></script>
</body>
</html>
